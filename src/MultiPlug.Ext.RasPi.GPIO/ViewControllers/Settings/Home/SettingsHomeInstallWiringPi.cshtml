@model MultiPlug.Base.Http.EdgeApp

<form action="" method="post" accept-charset="utf-8" enctype="application/x-www-form-urlencoded">
    <section class="row-fluid">

        <div class="row-fluid">
            <div class="box">
                <div class="span2">
                    <a style="line-height: 52px;" href="#"><img alt="Raspberry Pi Logo" src="@Raw(Model.Context.Paths.Assets)images/raspberry-pi.png"></a>
                </div>
                <div class="span8">
                    <p style="font-size:26px; line-height: 54px; text-align: center; margin: 0px;">Raspberry Pi GPIO</p>
                </div>
            </div>
        </div>

        @Include("MultiPlug.Ext.RasPi.GPIO.RaspPiGPIO_Settings_Navigation")

        @if (Model.Extension.Model.RestartMultiPlug)
        {
            <div class="alert">
                <strong>Reboot Required</strong> Changes have been made that require a system reboot to be applied.
            </div>
        }

        <div class="row-fluid">
            <div class="box">
                <h4>Prerequisite Not Met</h4>
                <div class="row-fluid">
                    <div class="well">
                        @if (Model.Extension.Model.RestartMultiPlug)
                        {
                            <div class="row-fluid">
                                <div class="span12">
                                    <div class="span12"><b>Please restart MultiPlug.</b></div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="row-fluid">
                                <div class="span12">
                                    <p>This extension requires WiringPi 3.181 to be installed.</p>
                                </div>
                            </div>
                            <div class="row-fluid">
                                <div class="span12">
                                    <a class="btn btn-blue btn-install" href="@Raw(Model.Context.Paths.APIs)install/">Install</a>
                                </div>
                            </div>
                            <div class="row-fluid">
                                <div class="span12">
                                    <p>Alternatively you can <a href="@Raw(Model.Context.Paths.Assets)downloads/wiringpi_3.181.deb">download it here</a> and install it using the following command:</p>
                                    <blockquote>
                                        <p>sudo apt install ./wiringpi_3.181.deb</p>
                                    </blockquote>
                                    <p>Restart MultiPlug once this is complete.</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
</form>

<script>
    $(".btn-install").click(function (event) {
        event.preventDefault();

        $.post($(this).attr('href'), function (data) {
        })
        .done(function () {
            alert("Install Complete. Restart MultiPlug.");
            location.reload();
        })
        .fail(function (xhr, status, error) {
            alert("Install Error " + xhr.responseJSON.errorMessage);
        });
    });

</script>
